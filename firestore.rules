rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /records/{recordId} {
      allow create: if request.resource.data.schemaVersion == 2
        && request.resource.data.eventType == 'calculator_result'
        && request.resource.data.sessionId is string
        && request.resource.data.sessionId.size() <= 64
        && request.resource.data.productLine in ['ipad', 'mac']
        && request.resource.data.product is string
        && request.resource.data.model is string
        && request.resource.data.recommendation is string
        && request.resource.data.recommendation.size() <= 500
        && request.resource.data.final is number
        && request.resource.data.final >= 0
        && request.resource.data.createdAt is number;

      allow read: if isAdmin();
      allow update, delete: if false;
    }

    match /admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
